# 1. Evitar que se listen los archivos de esta carpeta
Options -Indexes

# 2. Bloquear el acceso a archivos de datos y configuración
# Esto impide que descarguen fsm_database.txt o lean archivos de sistema
<FilesMatch "\.(db|log|ini|txt|md|sql|htaccess)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# 3. PERMITIR el procesamiento de tus formularios (POST y GET)
# Esto asegura que procesar_login.php, procesar_perfil.php, etc., funcionen siempre
<FilesMatch "\.(php)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Allow from all
    </IfModule>
</FilesMatch>